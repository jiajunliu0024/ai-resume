{
  "manifest_version": 3,
  "name": "Resume Tailor",
  "description": "Tailor resumes and cover letters from the current job description.",
  "version": "0.1.0",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; frame-src 'self' blob: data:; worker-src 'self'"
  },
  "action": {},
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.deepseek.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "https://api.mistral.ai/*",
    "https://api.x.ai/*",
    "https://openrouter.ai/*",
    "https://api.together.xyz/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["index.html", "assets/*", "resume-templates/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
